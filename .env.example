# Bright Data — Official Live Context (optional)
# Required when BRIGHT_DATA_ENABLED = true in src/config/feature-flags.ts
# Get your API key from https://brightdata.com/cp/setting/users
# Create a SERP API zone at https://brightdata.com/cp/zones
BRIGHTDATA_API_KEY=
BRIGHT_DATA_SERP_ZONE=serp_api

# For LOCAL dev: point API calls to your Vercel deployment (must have BRIGHTDATA_API_KEY in Vercel)
# Copy .env.example to .env.local and set your Vercel URL, e.g.:
# VITE_API_BASE=https://my-address-my-city-xxxx.vercel.app
VITE_API_BASE=
